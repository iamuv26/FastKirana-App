# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/fastkirana"
DIRECT_URL="postgresql://postgres:password@localhost:5432/fastkirana"

# NextAuth
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Upstash Redis
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Sheets Sync
INVENTORY_SYNC_TOKEN="your-secure-sync-token-here"

# Resend Mail
RESEND_API_KEY="your-resend-api-key-here"

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN="your-meta-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="your-meta-phone-number-id"
WHATSAPP_TEMPLATE_NAME="" # Set this only if you want to use a registered template (optional)

# Expo/React Native specific configurations
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000/api"
